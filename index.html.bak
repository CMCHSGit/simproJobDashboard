<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>simPRO Daily Job Dashboard</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #ffffff;
      --bg-sec:    #f5f5f4;
      --bg-ter:    #f0efeb;
      --text:      #1a1a18;
      --text-sec:  #5f5e5a;
      --text-ter:  #888780;
      --border:    rgba(0,0,0,0.12);
      --border-md: rgba(0,0,0,0.22);
      --radius-md: 8px;
      --radius-lg: 12px;
      --info-bg:   #e6f1fb;
      --info-text: #185fa5;
      --info-bdr:  #85b7eb;
      --warn-bg:   #faeeda;
      --warn-text: #854f0b;
      --success-bg:#eaf3de;
      --success-text:#3b6d11;
      --danger-bg: #fcebeb;
      --danger-text:#a32d2d;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg:        #1e1e1c;
        --bg-sec:    #2a2a28;
        --bg-ter:    #242422;
        --text:      #f0efeb;
        --text-sec:  #b4b2a9;
        --text-ter:  #888780;
        --border:    rgba(255,255,255,0.1);
        --border-md: rgba(255,255,255,0.2);
        --info-bg:   #0c447c;
        --info-text: #b5d4f4;
        --info-bdr:  #378add;
        --warn-bg:   #633806;
        --warn-text: #fac775;
        --success-bg:#27500a;
        --success-text:#c0dd97;
        --danger-bg: #791f1f;
        --danger-text:#f7c1c1;
      }
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: var(--bg-ter);
      color: var(--text);
      font-size: 14px;
      line-height: 1.5;
      min-height: 100vh;
    }

    /* ── Layout ── */
    .shell {
      max-width: 1100px;
      margin: 0 auto;
      background: var(--bg);
      min-height: 100vh;
      border-left: 0.5px solid var(--border);
      border-right: 0.5px solid var(--border);
    }

    /* ── Top bar ── */
    .top-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 20px;
      border-bottom: 0.5px solid var(--border);
      flex-wrap: wrap;
      gap: 10px;
    }
    .top-bar h1 { font-size: 17px; font-weight: 500; }
    .top-bar .sub { font-size: 12px; color: var(--text-sec); margin-top: 2px; }
    .top-right { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
    .last-updated { font-size: 11px; color: var(--text-ter); }

    /* ── Upload zone ── */
    .upload-section {
      padding: 16px 20px;
      border-bottom: 0.5px solid var(--border);
    }
    .upload-label { font-size: 12px; color: var(--text-sec); margin-bottom: 8px; font-weight: 500; }
    .drop-zone {
      border: 1.5px dashed var(--border-md);
      border-radius: var(--radius-lg);
      padding: 20px;
      text-align: center;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
      background: var(--bg-sec);
    }
    .drop-zone:hover, .drop-zone.drag-over {
      border-color: var(--info-text);
      background: var(--info-bg);
    }
    .drop-zone.loaded {
      border-style: solid;
      border-color: var(--success-text);
      background: var(--success-bg);
    }
    .drop-zone p { font-size: 13px; color: var(--text-sec); }
    .drop-zone .hint { font-size: 11px; color: var(--text-ter); margin-top: 4px; }
    .drop-zone.loaded p { color: var(--success-text); font-weight: 500; }
    #file-input { display: none; }

    /* ── Stats bar ── */
    .stats-bar {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      padding: 14px 20px;
      border-bottom: 0.5px solid var(--border);
    }
    .stat {
      background: var(--bg-sec);
      border-radius: var(--radius-md);
      padding: 10px 14px;
    }
    .stat-label { font-size: 11px; color: var(--text-sec); margin-bottom: 3px; text-transform: uppercase; letter-spacing: 0.04em; }
    .stat-value { font-size: 26px; font-weight: 500; }
    .stat-value.danger { color: var(--danger-text); }
    .stat-value.warn   { color: var(--warn-text); }
    .stat-value.success{ color: var(--success-text); }

    /* ── Filters ── */
    .filters {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 20px;
      border-bottom: 0.5px solid var(--border);
      flex-wrap: wrap;
    }
    .filter-group { display: flex; align-items: center; gap: 7px; }
    .filter-group label { font-size: 12px; color: var(--text-sec); white-space: nowrap; }
    select {
      font-size: 13px;
      padding: 5px 9px;
      border-radius: var(--radius-md);
      border: 0.5px solid var(--border-md);
      background: var(--bg);
      color: var(--text);
      cursor: pointer;
    }
    .cat-pills { display: flex; gap: 6px; flex-wrap: wrap; }
    .pill {
      padding: 4px 13px;
      font-size: 12px;
      border: 0.5px solid var(--border-md);
      border-radius: 20px;
      cursor: pointer;
      background: transparent;
      color: var(--text-sec);
      transition: background 0.1s;
    }
    .pill.active-all    { background: var(--bg-sec);     color: var(--text);         border-color: var(--border-md); font-weight: 500; }
    .pill.active-repair { background: #faece7;            color: #993c1d;              border-color: #f0997b; font-weight: 500; }
    .pill.active-testing{ background: var(--info-bg);    color: var(--info-text);    border-color: var(--info-bdr); font-weight: 500; }
    .pill.active-pm     { background: var(--success-bg); color: var(--success-text); border-color: #97c459; font-weight: 500; }

    /* ── Sort row ── */
    .sort-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 20px;
      border-bottom: 0.5px solid var(--border);
    }
    .sort-row .count { font-size: 12px; color: var(--text-ter); }
    .sort-group { display: flex; align-items: center; gap: 7px; }
    .sort-group label { font-size: 12px; color: var(--text-sec); }

    /* ── Job list ── */
    .jobs-list {
      padding: 14px 20px;
      display: flex;
      flex-direction: column;
      gap: 9px;
    }

    .job-card {
      background: var(--bg);
      border: 0.5px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 12px 14px;
      display: grid;
      grid-template-columns: 10px 1fr auto;
      gap: 12px;
      align-items: start;
      transition: border-color 0.1s;
    }
    .job-card:hover { border-color: var(--border-md); }
    .job-card.priority-high  { border-left: 3px solid #e24b4a; }
    .job-card.priority-medium{ border-left: 3px solid #ef9f27; }
    .job-card.priority-low   { border-left: 3px solid #639922; }

    .priority-dot { width: 10px; height: 10px; border-radius: 50%; margin-top: 4px; flex-shrink: 0; }
    .dot-high   { background: #e24b4a; }
    .dot-medium { background: #ef9f27; }
    .dot-low    { background: #639922; }

    .job-meta { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
    .job-header { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
    .job-num   { font-size: 13px; font-weight: 500; color: var(--text); white-space: nowrap; }
    .job-title { font-size: 13px; color: var(--text-sec); }
    .job-addr  { font-size: 12px; color: var(--text-ter); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .job-tags  { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 2px; }

    .tag {
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 10px;
      font-weight: 500;
      white-space: nowrap;
    }
    .tag-repair    { background: #faece7; color: #993c1d; }
    .tag-testing   { background: var(--info-bg); color: var(--info-text); }
    .tag-pm        { background: var(--success-bg); color: var(--success-text); }
    .tag-high      { background: var(--danger-bg); color: var(--danger-text); }
    .tag-progress  { background: var(--warn-bg); color: var(--warn-text); }
    .tag-scheduled { background: var(--bg-sec); color: var(--text-sec); }
    .tag-completed { background: var(--success-bg); color: var(--success-text); }

    .job-right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 5px;
      flex-shrink: 0;
    }
    .tech-badge {
      font-size: 11px;
      padding: 3px 9px;
      border-radius: var(--radius-md);
      background: var(--bg-sec);
      color: var(--text-sec);
      border: 0.5px solid var(--border);
      white-space: nowrap;
    }
    .job-time { font-size: 12px; color: var(--text-sec); }

    .empty {
      text-align: center;
      padding: 40px 20px;
      color: var(--text-ter);
      font-size: 13px;
    }
    .empty strong { display: block; font-size: 15px; font-weight: 500; color: var(--text-sec); margin-bottom: 6px; }

    /* ── Buttons ── */
    .btn {
      font-size: 12px;
      padding: 5px 12px;
      border: 0.5px solid var(--border-md);
      border-radius: var(--radius-md);
      background: transparent;
      color: var(--text-sec);
      cursor: pointer;
    }
    .btn:hover { background: var(--bg-sec); }
    .btn-primary {
      background: var(--info-bg);
      color: var(--info-text);
      border-color: var(--info-bdr);
    }
    .btn-primary:hover { opacity: 0.85; }

    /* ── Column mapping modal ── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.45);
      z-index: 100;
      align-items: center;
      justify-content: center;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: var(--bg);
      border-radius: var(--radius-lg);
      padding: 20px 24px;
      width: 480px;
      max-width: 95vw;
      border: 0.5px solid var(--border-md);
    }
    .modal h2 { font-size: 15px; font-weight: 500; margin-bottom: 4px; }
    .modal p  { font-size: 12px; color: var(--text-sec); margin-bottom: 16px; }
    .map-grid { display: grid; grid-template-columns: 140px 1fr; gap: 8px 12px; align-items: center; margin-bottom: 16px; }
    .map-grid .field-name { font-size: 12px; color: var(--text-sec); font-weight: 500; }
    .map-grid select { width: 100%; }
    .modal-actions { display: flex; gap: 8px; justify-content: flex-end; }

    /* ── Footer ── */
    footer {
      padding: 12px 20px;
      border-top: 0.5px solid var(--border);
      font-size: 11px;
      color: var(--text-ter);
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 6px;
    }

    @media (max-width: 600px) {
      .stats-bar { grid-template-columns: repeat(2, 1fr); }
      .job-card  { grid-template-columns: 10px 1fr; }
      .job-right { display: none; }
    }
  </style>
</head>
<body>
<div class="shell">

  <!-- Top bar -->
  <div class="top-bar">
    <div>
      <h1>simPRO daily job dashboard</h1>
      <div class="sub" id="today-date"></div>
    </div>
    <div class="top-right">
      <span class="last-updated" id="last-updated"></span>
      <button class="btn" onclick="clearData()">Clear</button>
      <button class="btn btn-primary" onclick="document.getElementById('file-input').click()">Load CSV</button>
    </div>
  </div>

  <!-- Upload zone -->
  <div class="upload-section">
    <div class="upload-label">simPRO export — drag & drop or click "Load CSV"</div>
    <div class="drop-zone" id="drop-zone" onclick="document.getElementById('file-input').click()">
      <p id="drop-text">Drop your simPRO CSV export here</p>
      <div class="hint" id="drop-hint">Exports from simPRO → Jobs → Export to CSV. Expected columns listed in README.md</div>
    </div>
    <input type="file" id="file-input" accept=".csv,.txt" onchange="handleFile(event)" />
  </div>

  <!-- Stats -->
  <div class="stats-bar">
    <div class="stat">
      <div class="stat-label">Total jobs</div>
      <div class="stat-value" id="s-total">—</div>
    </div>
    <div class="stat">
      <div class="stat-label">High priority</div>
      <div class="stat-value danger" id="s-high">—</div>
    </div>
    <div class="stat">
      <div class="stat-label">In progress</div>
      <div class="stat-value warn" id="s-progress">—</div>
    </div>
    <div class="stat">
      <div class="stat-label">Completed today</div>
      <div class="stat-value success" id="s-done">—</div>
    </div>
  </div>

  <!-- Filters -->
  <div class="filters">
    <div class="filter-group">
      <label>Technician</label>
      <select id="tech-filter" onchange="renderJobs()">
        <option value="">All technicians</option>
      </select>
    </div>
    <div class="filter-group">
      <label>Status</label>
      <select id="status-filter" onchange="renderJobs()">
        <option value="">All statuses</option>
      </select>
    </div>
    <div class="cat-pills" id="cat-pills">
      <button class="pill active-all" data-cat="" onclick="setCat(this)">All</button>
      <button class="pill" data-cat="Repair" onclick="setCat(this)">Repair</button>
      <button class="pill" data-cat="Testing" onclick="setCat(this)">Testing</button>
      <button class="pill" data-cat="PM" onclick="setCat(this)">Prev. maintenance</button>
    </div>
  </div>

  <!-- Sort row -->
  <div class="sort-row">
    <span class="count" id="job-count"></span>
    <div class="sort-group">
      <label>Sort by</label>
      <select id="sort-by" onchange="renderJobs()">
        <option value="priority">Priority</option>
        <option value="time">Scheduled time</option>
        <option value="jobnum">Job number</option>
        <option value="tech">Technician</option>
      </select>
    </div>
  </div>

  <!-- Jobs -->
  <div class="jobs-list" id="jobs-list">
    <div class="empty">
      <strong>No jobs loaded</strong>
      Load a simPRO CSV export using the button above or drag a file onto the upload zone.
    </div>
  </div>

  <!-- Footer -->
  <footer>
    <span>simPRO Daily Dashboard — CSV mode</span>
    <span>
      <a href="https://github.com/your-org/simpro-dashboard" style="color:var(--text-ter)">GitHub</a>
      &nbsp;·&nbsp;
      <a href="README.md" style="color:var(--text-ter)">README</a>
    </span>
  </footer>
</div>

<!-- Column mapping modal -->
<div class="modal-overlay" id="map-modal">
  <div class="modal">
    <h2>Map CSV columns</h2>
    <p>We couldn't auto-detect your simPRO column names. Match each field below to a column from your file, then click Apply.</p>
    <div class="map-grid" id="map-grid"></div>
    <div class="modal-actions">
      <button class="btn" onclick="closeModal()">Cancel</button>
      <button class="btn btn-primary" onclick="applyMapping()">Apply mapping</button>
    </div>
  </div>
</div>

<script>
// ── State ──────────────────────────────────────────────────────────────────
let allJobs    = [];
let activeCat  = '';
let csvHeaders = [];
let rawRows    = [];

// Field definitions: internal key → display label → known simPRO header variants
const FIELDS = [
  { key: 'num',      label: 'Job number',     variants: ['job no','job number','job #','id','job id'] },
  { key: 'title',    label: 'Job title',       variants: ['title','job title','description','subject','summary'] },
  { key: 'cat',      label: 'Category',        variants: ['category','job category','type','job type','work type'] },
  { key: 'tech',     label: 'Technician',      variants: ['technician','assigned to','tech','engineer','staff','contractor'] },
  { key: 'time',     label: 'Scheduled time',  variants: ['scheduled time','schedule time','start time','time','scheduled start'] },
  { key: 'date',     label: 'Scheduled date',  variants: ['scheduled date','schedule date','date','job date','start date'] },
  { key: 'addr',     label: 'Site address',    variants: ['site address','address','location','site','customer address'] },
  { key: 'status',   label: 'Status',          variants: ['status','job status','stage'] },
  { key: 'priority', label: 'Priority',        variants: ['priority','urgency','importance'] },
];

// ── Init ───────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('today-date').textContent =
    new Date().toLocaleDateString('en-NZ', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

  // Drag-drop
  const dz = document.getElementById('drop-zone');
  dz.addEventListener('dragover',  e => { e.preventDefault(); dz.classList.add('drag-over'); });
  dz.addEventListener('dragleave', () => dz.classList.remove('drag-over'));
  dz.addEventListener('drop', e => {
    e.preventDefault(); dz.classList.remove('drag-over');
    const f = e.dataTransfer.files[0];
    if (f) processFile(f);
  });
});

// ── File handling ──────────────────────────────────────────────────────────
function handleFile(e) {
  const f = e.target.files[0];
  if (f) processFile(f);
  e.target.value = '';
}

function processFile(file) {
  const reader = new FileReader();
  reader.onload = ev => parseCSV(ev.target.result, file.name);
  reader.readAsText(file);
}

function parseCSV(text, filename) {
  const lines = text.trim().split(/\r?\n/);
  if (lines.length < 2) { alert('CSV appears empty or has only a header row.'); return; }

  csvHeaders = splitCSVLine(lines[0]).map(h => h.trim().replace(/^"|"$/g, '').toLowerCase());
  rawRows    = lines.slice(1).filter(l => l.trim()).map(l =>
    splitCSVLine(l).map(c => c.trim().replace(/^"|"$/g, ''))
  );

  // Auto-detect column mapping
  const mapping = autoMap(csvHeaders);

  if (!mapping.num && !mapping.title) {
    // Show manual mapping modal
    showModal(filename);
    return;
  }

  applyMappingToRows(mapping, filename);
}

function autoMap(headers) {
  const mapping = {};
  for (const field of FIELDS) {
    const idx = headers.findIndex(h => field.variants.some(v => h === v || h.includes(v)));
    if (idx !== -1) mapping[field.key] = idx;
  }
  return mapping;
}

function applyMappingToRows(mapping, filename) {
  allJobs = rawRows.map(cols => {
    const get = key => mapping[key] !== undefined ? (cols[mapping[key]] || '').trim() : '';
    return {
      num:      get('num')      || '—',
      title:    get('title')    || 'Untitled job',
      cat:      normCat(get('cat')),
      tech:     get('tech')     || 'Unassigned',
      time:     get('time')     || '',
      date:     get('date')     || '',
      addr:     get('addr')     || '',
      status:   normStatus(get('status')),
      priority: normPriority(get('priority')),
    };
  }).filter(j => j.num !== '—' || j.title !== 'Untitled job');

  setLoaded(filename);
  populateFilterDropdowns();
  updateStats();
  renderJobs();
}

// ── Normalise values ───────────────────────────────────────────────────────
function normCat(raw) {
  const r = raw.toLowerCase();
  if (r.includes('repair') || r.includes('fault') || r.includes('breakdown')) return 'Repair';
  if (r.includes('test'))  return 'Testing';
  if (r.includes('prev') || r.includes('pm') || r.includes('maintenance') || r.includes('service')) return 'PM';
  return raw || 'Other';
}

function normStatus(raw) {
  const r = raw.toLowerCase();
  if (r.includes('progress') || r.includes('active') || r.includes('started')) return 'In progress';
  if (r.includes('complet') || r.includes('done') || r.includes('closed'))      return 'Completed';
  if (r.includes('schedul') || r.includes('pending') || r.includes('open'))     return 'Scheduled';
  if (r.includes('cancel'))                                                       return 'Cancelled';
  return raw || 'Scheduled';
}

function normPriority(raw) {
  const r = raw.toLowerCase();
  if (r.includes('high') || r.includes('urgent') || r.includes('critical') || r === '1') return 'High';
  if (r.includes('low')  || r === '3') return 'Low';
  if (r.includes('med')  || r === '2') return 'Medium';
  return 'Medium';
}

// ── CSV parser (handles quoted fields) ────────────────────────────────────
function splitCSVLine(line) {
  const result = [];
  let cur = '', inQ = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (ch === '"' && !inQ) { inQ = true; continue; }
    if (ch === '"' &&  inQ) { if (line[i+1] === '"') { cur += '"'; i++; } else inQ = false; continue; }
    if (ch === ',' && !inQ) { result.push(cur); cur = ''; continue; }
    cur += ch;
  }
  result.push(cur);
  return result;
}

// ── Manual mapping modal ───────────────────────────────────────────────────
let pendingFilename = '';
function showModal(filename) {
  pendingFilename = filename;
  const grid = document.getElementById('map-grid');
  grid.innerHTML = FIELDS.map(f => `
    <span class="field-name">${f.label}</span>
    <select id="map-${f.key}">
      <option value="">— skip —</option>
      ${csvHeaders.map((h, i) => `<option value="${i}">${h}</option>`).join('')}
    </select>
  `).join('');

  // Pre-select best guess even if not perfect match
  FIELDS.forEach(f => {
    const sel = document.getElementById('map-' + f.key);
    const idx = csvHeaders.findIndex(h => f.variants.some(v => h.includes(v)));
    if (idx !== -1) sel.value = String(idx);
  });

  document.getElementById('map-modal').classList.add('open');
}

function closeModal() {
  document.getElementById('map-modal').classList.remove('open');
}

function applyMapping() {
  const mapping = {};
  FIELDS.forEach(f => {
    const val = document.getElementById('map-' + f.key).value;
    if (val !== '') mapping[f.key] = parseInt(val, 10);
  });
  closeModal();
  applyMappingToRows(mapping, pendingFilename);
}

// ── UI updates ─────────────────────────────────────────────────────────────
function setLoaded(filename) {
  const dz = document.getElementById('drop-zone');
  dz.classList.add('loaded');
  document.getElementById('drop-text').textContent = `${allJobs.length} jobs loaded from ${filename}`;
  document.getElementById('drop-hint').textContent = 'Drop another file to replace, or click "Clear" to reset.';
  document.getElementById('last-updated').textContent = 'Updated ' + new Date().toLocaleTimeString('en-NZ', { hour: '2-digit', minute: '2-digit' });
}

function clearData() {
  allJobs = []; activeCat = '';
  const dz = document.getElementById('drop-zone');
  dz.classList.remove('loaded');
  document.getElementById('drop-text').textContent = 'Drop your simPRO CSV export here';
  document.getElementById('drop-hint').textContent = 'Exports from simPRO → Jobs → Export to CSV. Expected columns listed in README.md';
  document.getElementById('last-updated').textContent = '';
  ['s-total','s-high','s-progress','s-done'].forEach(id => document.getElementById(id).textContent = '—');
  document.getElementById('tech-filter').innerHTML   = '<option value="">All technicians</option>';
  document.getElementById('status-filter').innerHTML = '<option value="">All statuses</option>';
  document.getElementById('jobs-list').innerHTML = `
    <div class="empty">
      <strong>No jobs loaded</strong>
      Load a simPRO CSV export using the button above or drag a file onto the upload zone.
    </div>`;
  document.getElementById('job-count').textContent = '';
  setCatByValue('');
}

function populateFilterDropdowns() {
  const techs    = [...new Set(allJobs.map(j => j.tech))].sort();
  const statuses = [...new Set(allJobs.map(j => j.status))].sort();

  document.getElementById('tech-filter').innerHTML =
    '<option value="">All technicians</option>' +
    techs.map(t => `<option value="${t}">${t}</option>`).join('');

  document.getElementById('status-filter').innerHTML =
    '<option value="">All statuses</option>' +
    statuses.map(s => `<option value="${s}">${s}</option>`).join('');
}

function updateStats() {
  document.getElementById('s-total').textContent    = allJobs.length;
  document.getElementById('s-high').textContent     = allJobs.filter(j => j.priority === 'High').length;
  document.getElementById('s-progress').textContent = allJobs.filter(j => j.status === 'In progress').length;
  document.getElementById('s-done').textContent     = allJobs.filter(j => j.status === 'Completed').length;
}

// ── Category pills ─────────────────────────────────────────────────────────
function setCat(btn) {
  activeCat = btn.dataset.cat;
  document.querySelectorAll('.pill').forEach(b => b.className = 'pill');
  const cls = activeCat === ''        ? 'active-all'
            : activeCat === 'Repair'  ? 'active-repair'
            : activeCat === 'Testing' ? 'active-testing'
            : 'active-pm';
  btn.classList.add(cls);
  renderJobs();
}

function setCatByValue(val) {
  activeCat = val;
  document.querySelectorAll('.pill').forEach(b => {
    b.className = 'pill';
    if (b.dataset.cat === val) b.classList.add('active-all');
  });
}

// ── Render ─────────────────────────────────────────────────────────────────
function renderJobs() {
  const tech   = document.getElementById('tech-filter').value;
  const status = document.getElementById('status-filter').value;
  const sort   = document.getElementById('sort-by').value;
  const PRI    = { High: 0, Medium: 1, Low: 2 };

  let jobs = allJobs
    .filter(j => !tech   || j.tech   === tech)
    .filter(j => !status || j.status === status)
    .filter(j => !activeCat || j.cat === activeCat);

  if (sort === 'priority') jobs.sort((a, b) => PRI[a.priority] - PRI[b.priority] || a.time.localeCompare(b.time));
  else if (sort === 'time') jobs.sort((a, b) => a.time.localeCompare(b.time));
  else if (sort === 'jobnum') jobs.sort((a, b) => a.num.localeCompare(b.num, undefined, { numeric: true }));
  else if (sort === 'tech') jobs.sort((a, b) => a.tech.localeCompare(b.tech));

  document.getElementById('job-count').textContent =
    allJobs.length ? `Showing ${jobs.length} of ${allJobs.length} jobs` : '';

  const el = document.getElementById('jobs-list');

  if (!jobs.length) {
    el.innerHTML = `<div class="empty"><strong>No jobs match</strong>Try adjusting the filters above.</div>`;
    return;
  }

  const catTag = { Repair: 'tag-repair', Testing: 'tag-testing', PM: 'tag-pm' };
  const catLabel = { PM: 'Prev. maintenance' };
  const statusTag = { 'In progress': 'tag-progress', Completed: 'tag-completed', Scheduled: 'tag-scheduled', Cancelled: 'tag-scheduled' };
  const dotClass  = { High: 'dot-high', Medium: 'dot-medium', Low: 'dot-low' };
  const cardClass = { High: 'priority-high', Medium: 'priority-medium', Low: 'priority-low' };

  el.innerHTML = jobs.map(j => `
    <div class="job-card ${cardClass[j.priority] || ''}">
      <div class="priority-dot ${dotClass[j.priority] || 'dot-medium'}"></div>
      <div class="job-meta">
        <div class="job-header">
          <span class="job-num">${j.num}</span>
          <span class="job-title">${j.title}</span>
        </div>
        ${j.addr ? `<div class="job-addr">${j.addr}</div>` : ''}
        <div class="job-tags">
          ${j.cat ? `<span class="tag ${catTag[j.cat] || 'tag-scheduled'}">${catLabel[j.cat] || j.cat}</span>` : ''}
          <span class="tag ${statusTag[j.status] || 'tag-scheduled'}">${j.status}</span>
          ${j.priority === 'High' ? '<span class="tag tag-high">High priority</span>' : ''}
        </div>
      </div>
      <div class="job-right">
        <span class="tech-badge">${j.tech}</span>
        ${j.time ? `<span class="job-time">${j.time}</span>` : ''}
        ${j.date ? `<span class="job-time" style="font-size:11px">${j.date}</span>` : ''}
      </div>
    </div>
  `).join('');
}
</script>
</body>
</html>
